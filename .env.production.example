# ==============================================================
# .env untuk Production (Multipass / VPS)
# Salin ke .env di server, ISI semua nilai yang kosong
# ==============================================================

APP_NAME="DevoraV2"
APP_ENV=production
APP_KEY=           # Generate dengan: php artisan key:generate --show
APP_DEBUG=false
APP_URL=http://IP_MULTIPASS_ANDA  # Ganti dengan IP Multipass

APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# Logging (production: hanya error)
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# Database MySQL (wajib)
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=devora_db
DB_USERNAME=devora_user
DB_PASSWORD=GANTI_PASSWORD_KUAT_DI_SINI
DB_ROOT_PASSWORD=GANTI_ROOT_PASSWORD_KUAT_DI_SINI

# Session & Cache via Redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
CACHE_STORE=redis

# Redis
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# Email (gunakan SMTP service, contoh Mailtrap / Brevo / Gmail)
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp.mailtrap.io           # Ganti dengan SMTP provider Anda
MAIL_PORT=2525
MAIL_USERNAME=                        # Isi username SMTP
MAIL_PASSWORD=                        # Isi password SMTP
MAIL_FROM_ADDRESS="noreply@devora.app"
MAIL_FROM_NAME="DevoraV2"

# Google Books API (opsional)
GOOGLE_BOOKS_API_KEY=AIzaSyB8j1My2HArHrZk4DyNIbWhNyYEjpdah54
GEMINI_API_KEY=AIzaSyAKSZuL98Kxn0PmctJmknL3kpScHIwnNrg

VITE_APP_NAME="${APP_NAME}"

